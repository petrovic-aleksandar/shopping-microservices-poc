  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP Request Rate (req/s)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=~\"api-gateway|auth-service|order-service|payment-service|inventory-service\"}[5m])) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP 5xx Error Rate (%)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "100 * (sum(rate(http_server_requests_seconds_count{job=~\"api-gateway|auth-service|order-service|payment-service|inventory-service\",status=~\"5..\"}[5m])) by (job) / sum(rate(http_server_requests_seconds_count{job=~\"api-gateway|auth-service|order-service|payment-service|inventory-service\"}[5m])) by (job))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP p95 Latency (s)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=~\"api-gateway|auth-service|order-service|payment-service|inventory-service\"}[5m])) by (job, le))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM Heap Used (bytes)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\",job=~\"api-gateway|auth-service|order-service|payment-service|inventory-service\"}",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Process CPU Usage",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "process_cpu_usage{job=~\"api-gateway|auth-service|order-service|payment-service|inventory-service\"}",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Service Availability (up)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [
        {
          "expr": "up{job=~\"api-gateway|auth-service|order-service|payment-service|inventory-service\"}",
          "legendFormat": "{{job}}"
        }
      ]
    }
